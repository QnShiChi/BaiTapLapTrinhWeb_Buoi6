@model IEnumerable<Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<section class="admin-page">
    <div class="section-header">
        <div>
            <p class="eyebrow">Admin</p>
            <h1>Quản lý danh mục</h1>
        </div>
        <a asp-action="Create" class="button-primary">Thêm danh mục</a>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Mô tả</th>
                <th>Số sản phẩm</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.Description</td>
                <td>@category.Products.Count</td>
                <td class="admin-actions">
                    <a asp-action="Edit" asp-route-id="@category.Id">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="text-danger">Xóa</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
